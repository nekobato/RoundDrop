{
  "name": "round-drop",
  "private": true,
  "version": "1.6.2",
  "author": {
    "name": "nekobato",
    "email": "nekobato@gmail.com",
    "url": "https://nekobato.net"
  },
  "license": "MIT",
  "description": "Ring UI Application Launcher for macOS",
  "scripts": {
    "postinstall": "rm -rf node_modules/electron/dist && node node_modules/electron/install.js",
    "dev": "vite",
    "build:native": "node scripts/build-window-activator.mjs",
    "build": "pnpm build:native && vue-tsc && vite build && electron-builder --config electron-builder.config.cjs",
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "release": "pnpm build:native && vite build && electron-builder --publish always --config electron-builder.config.cjs",
    "build:icon": "electron-icon-builder --input=./public/icon.png --output=./public"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "dependencies": {
    "electron-store": "11.0.2",
    "file-icon": "6.0.0",
    "plist": "5.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "3.1.1",
    "@iconify/vue": "5.0.1",
    "@sentry/electron": "7.13.0",
    "@types/node": "25.9.3",
    "@types/plist": "3.0.5",
    "@vitejs/plugin-vue": "6.0.7",
    "@vueuse/integrations": "14.3.0",
    "electron": "42.4.0",
    "electron-builder": "26.15.3",
    "electron-icon-builder": "2.0.1",
    "electron-log": "5.4.4",
    "electron-updater": "6.8.9",
    "element-plus": "2.14.2",
    "fs-extra": "11.3.5",
    "nanoid": "5.1.11",
    "sass-embedded": "1.100.0",
    "sortablejs": "1.15.7",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-electron": "1.0.4",
    "vite-plugin-electron-renderer": "1.0.0",
    "vue": "3.5.38",
    "vue-tsc": "3.3.5"
  },
  "main": "dist-electron/main.js"
}
