# Required to send Sentry diagnostics from packaged builds.
VITE_SENTRY_DSN=

# Optional. Defaults to production/development based on the app runtime.
VITE_SENTRY_ENVIRONMENT=production

# Optional. Range: 0 to 1. Defaults to 0 to avoid performance event volume.
VITE_SENTRY_TRACES_SAMPLE_RATE=0

# Optional. Use these only for source map upload tooling, never with VITE_ prefix.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
